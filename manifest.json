{
  "manifest_version": 3,
  "name": "Claude RTL Fix",
  "version": "1.0.0",
  "description": "Fixes right-to-left text rendering for Persian responses in Claude.ai",
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "claude-rtl-fix@extension",
      "strict_min_version": "101.0"
    }
  }
}
